# .env.example — copy to .env and fill in real values
#
# NEVER commit .env to git.  This file is the template only.
#
# ── Alpaca credentials ────────────────────────────────────────────────────────
# Paper trading (default):  https://paper-api.alpaca.markets
# Live trading:             set APCA_LIVE=1 and use live keys
ALPACA_API_KEY=your-paper-api-key-here
ALPACA_API_SECRET=your-paper-api-secret-here

# Uncomment and set to 1 to switch to live trading (REAL MONEY — be careful)
# APCA_LIVE=1

# ── Email alerting (P4.2) ─────────────────────────────────────────────────────
# Gmail App Password (Google Account → Security → App passwords)
# Leave blank to disable email alerts even if alerts.enabled = true in config.
DOLLARBILL_SMTP_PASSWORD=

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | debug | trace
RUST_LOG=info
